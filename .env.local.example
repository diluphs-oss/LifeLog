# Supabase (Project Settings > API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gmail sending (Google Account > Security > App Passwords, needs 2FA enabled)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
REPORT_EMAIL_TO=you@gmail.com

# Telegram (message @BotFather to create a bot, get token; message @userinfobot to get your chat id)
TELEGRAM_BOT_TOKEN=123456:ABC-yourtoken
TELEGRAM_CHAT_ID=123456789
